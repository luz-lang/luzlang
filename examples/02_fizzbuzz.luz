# 02 - FizzBuzz
# Multiples of 3 → "Fizz", 5 → "Buzz", both → "FizzBuzz".
# Shows: for loops, if/elif/else, const, typed variables.

const LIMIT: int = 100

function fizzbuzz(n: int) -> string {
    if n % 15 == 0 { return "FizzBuzz" }
    if n % 3  == 0 { return "Fizz" }
    if n % 5  == 0 { return "Buzz" }
    return to_str(n)
}

for i = 1 to LIMIT {
    write(fizzbuzz(i))
}
