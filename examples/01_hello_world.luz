# 01 - Hello World
# Basic I/O, typed variables, and format strings.

greeting: string = "Hello, World!"
write(greeting)

name: string = listen("What is your name? ")
write($"Nice to meet you, {name}!")

age_str: string = listen("How old are you? ")
age: int = to_int(age_str)
write($"In 10 years you will be {age + 10} years old.")
